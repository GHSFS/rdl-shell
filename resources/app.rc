// Win32 resource script — embeds version metadata + manifest into the DLL.

#include <winuser.h>

#ifndef RT_MANIFEST
#define RT_MANIFEST 24
#endif

ISOLATIONAWARE_MANIFEST_RESOURCE_ID RT_MANIFEST "app.manifest"

1 VERSIONINFO
FILEVERSION     0,1,0,0
PRODUCTVERSION  0,1,0,0
FILEFLAGSMASK   0x3FL
FILEFLAGS       0x0L
FILEOS          0x40004L
FILETYPE        0x2L          // VFT_DLL
FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "GHSFS"
            VALUE "FileDescription",  "rdl-shell context menu extension"
            VALUE "FileVersion",      "0.1.0.0"
            VALUE "InternalName",     "rdl_shell"
            VALUE "LegalCopyright",   "Copyright (c) 2026 GHSFS"
            VALUE "OriginalFilename", "rdl_shell.dll"
            VALUE "ProductName",      "remote-dl shell extension"
            VALUE "ProductVersion",   "0.1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
